[ext_resource type="Resource" path="res://resources/quest_outcomes/quest_outcome_ruins_delve_success.tres" id="3_success"]
[ext_resource type="Resource" path="res://resources/quest_outcomes/quest_outcome_ruins_delve_danger.tres" id="4_danger"]

[resource]
script = ExtResource("1_profile")
